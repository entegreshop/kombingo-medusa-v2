FROM node:20-alpine AS runner
WORKDIR /app

COPY . .

# Disable root package.json to bypass npm workspace resolution bugs
RUN mv package.json package.json.bak || true

WORKDIR /app/apps/backend
RUN npm install --legacy-peer-deps

EXPOSE 9000

# Run build and start at runtime to bypass Docker build memory limits and hangs
CMD ["sh", "-c", "npm run build && npm run start"]
